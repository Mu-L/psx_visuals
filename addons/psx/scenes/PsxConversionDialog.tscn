label_text = "Overwrite Resources"

[node name="value" type="CheckBox" parent="ScrollContainer/list/resource_overwrite" unique_id=1029408541]
layout_mode = 2
mouse_filter = 1

[node name="resource_deep" parent="ScrollContainer/list" unique_id=1673322767 instance=ExtResource("1_qjfr0")]
layout_mode = 2
tooltip_text = "If enabled, this will attempt to replace the material(s) inside resources which a Node uses, e.g. MeshInstance3D.mesh, where it is available. This may alter other Resources in the FileSystem.

If disabled or unavailable, the nearest mutable override slot in that Node will be used (surface_material_override in MeshInstance3D, material_override in others. This only affects PackedScenes/Nodes)."
label_text = "Deep"

